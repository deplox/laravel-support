{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "deplox/laravel-support",
    "type": "library",
    "description": "Opinionated support for Laravel projects.",
    "keywords": [
        "laravel",
        "eloquent",
        "traits",
        "concerns",
        "validation",
        "password-reset",
        "single-table-inheritance",
        "support"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Jona Goldman",
            "email": "jonagoldman@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel/framework": "^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Deplox\\Support\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Deplox\\Support\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "stan": "phpstan analyse --memory-limit=512M"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Deplox\\Support\\SupportServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
